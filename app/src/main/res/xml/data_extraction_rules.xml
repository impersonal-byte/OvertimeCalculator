<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include: Room database (business core data) -->
        <include domain="database" path="overtime-calculator.db" />
        
        <!-- Include: User appearance preferences -->
        <include domain="sharedpref" path="overtime-preferences.xml" />
        
        <!-- Other SharedPreferences/DataStore files stay out of backup by omission: only the
             exact database and overtime-preferences.xml paths above are included. -->
    </cloud-backup>
    <device-transfer>
        <!-- Include: Room database (business core data) -->
        <include domain="database" path="overtime-calculator.db" />
        
        <!-- Include: User appearance preferences -->
        <include domain="sharedpref" path="overtime-preferences.xml" />
        
        <!-- Other SharedPreferences/DataStore files stay out of backup by omission: only the
             exact database and overtime-preferences.xml paths above are included. -->
    </device-transfer>
</data-extraction-rules>
